# Core app
DATABASE_URL="postgres://USER:PASSWORD@localhost:5432/apex_rivals"

# Better Auth
# Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET="replace-with-a-long-random-secret"
BETTER_AUTH_URL="http://localhost:3000"

# Google OAuth
GOOGLE_CLIENT_ID="replace-with-google-client-id"
GOOGLE_CLIENT_SECRET="replace-with-google-client-secret"

# Email (Gmail SMTP app password)
GMAIL_USER="your-email@gmail.com"
GMAIL_APP_PASSWORD="replace-with-gmail-app-password"

# Public URL used in email templates
NEXT_PUBLIC_BASE_URL="http://localhost:3000"

# External API used by seed script
JOLPICA_URL="https://api.jolpi.ca/ergast/f1"
